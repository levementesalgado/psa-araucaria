#!/bin/sh

# Gradle wrapper launcher (without wrapper jar)
GRADLE_VERSION=8.5
GRADLE_DIR="$HOME/.gradle/wrapper/dists"
GRADLE_URL="https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"

# Find or download Gradle
find_gradle() {
    find "$GRADLE_DIR" -name "gradle-${GRADLE_VERSION}-bin.zip" -o -name "gradle-${GRADLE_VERSION}" -type d 2>/dev/null | head -1
}

GRADLE_HOME=$(find_gradle)
if [ -z "$GRADLE_HOME" ]; then
    echo "Downloading Gradle ${GRADLE_VERSION}..."
    mkdir -p "$GRADLE_DIR"
    curl -sL "$GRADLE_URL" -o "/tmp/gradle-${GRADLE_VERSION}-bin.zip"
    unzip -q "/tmp/gradle-${GRADLE_VERSION}-bin.zip" -d "$GRADLE_DIR"
    GRADLE_HOME="$GRADLE_DIR/gradle-${GRADLE_VERSION}"
fi

exec "$GRADLE_HOME/bin/gradle" "$@"
